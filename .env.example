# Mapbox (required for the map)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# PostgreSQL — use Railway Postgres or local Postgres while developing
# Local dev: use the PUBLIC URL from Railway Postgres (not postgres.railway.internal)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Optional: set in production
# AUTH_URL=https://your-domain.com

# Resend (transactional email)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Worldly <hello@yourdomain.com>

# AWS Polly (optional — for npm run generate-pronunciations)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# POLLY_VOICE=Joanna
# POLLY_ENGINE=neural
